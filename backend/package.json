{
  "name": "projtrack-backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node scripts/start-dev-local.cjs",
    "worker": "node -r ts-node/register src/worker.ts",
    "dev:worker": "node -r ts-node/register src/worker.ts",
    "serve:local": "node scripts/start-dev-local.cjs",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "build": "tsc -p tsconfig.json",
    "test": "node scripts/production-hardening-checks.cjs",
    "security:secrets": "node ../scripts/secret-scan.mjs",
    "check:release-hygiene": "node ../scripts/release-hygiene-check.mjs",
    "smoke": "node scripts/smoke.js",
    "smoke:storage": "node scripts/object-storage-smoke.js",
    "smoke:mail": "node scripts/mail-staging-smoke.js",
    "smoke:academic-structure": "node scripts/academic-structure-smoke.js",
    "cleanup:seed-data": "node scripts/cleanup-seed-data.js",
    "data:hygiene": "node scripts/local-data-hygiene.js",
    "mail:testmail": "node scripts/testmail-inbox.js",
    "duplicates:scan": "tsx -r dotenv/config scripts/scan-duplicates.ts",
    "backfill:subject-sections": "node scripts/backfill-subject-sections.cjs",
    "backfill:submission-events": "node scripts/backfill-submission-events.cjs",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "start:prod": "node dist/main.js",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:up": "scripts\\docker-compose-wrapper.cmd -f docker-compose.postgres.yml up -d",
    "db:down": "scripts\\docker-compose-wrapper.cmd -f docker-compose.postgres.yml down",
    "storage:up": "scripts\\docker-compose-wrapper.cmd -f docker-compose.storage.yml up -d",
    "storage:down": "scripts\\docker-compose-wrapper.cmd -f docker-compose.storage.yml down",
    "infra:up": "scripts\\docker-compose-wrapper.cmd -f docker-compose.postgres.yml -f docker-compose.storage.yml up -d",
    "infra:down": "scripts\\docker-compose-wrapper.cmd -f docker-compose.postgres.yml -f docker-compose.storage.yml down",
    "dev:raw": "node -r ts-node/register src/main.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "body-parser": "^2.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "file-type": "^16.5.4",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "resend": "6.1.3",
    "rxjs": "^7.8.1",
    "svix": "^1.92.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "multer": "2.1.1"
  }
}
