# Example environment variables for production environment

# Database Configuration
DATABASE_URL=postgresql://username:password@production-host:5432/projtrack_prod

# Application URLs
APP_URL=https://www.projtrack.codes
FRONTEND_URL=https://www.projtrack.codes
BACKEND_URL=https://api.projtrack.codes
CORS_ORIGINS=https://www.projtrack.codes
TRUST_PROXY=true

# Authentication Secrets (use secure values in production)
JWT_ACCESS_SECRET=your-secure-access-secret-for-production
JWT_REFRESH_SECRET=your-secure-refresh-secret-for-production
ACCOUNT_ACTION_TOKEN_ENC_KEY=your-secure-encryption-key-for-production
JWT_ISSUER=projtrack
JWT_AUDIENCE=projtrack-users
JWT_KEY_ID=prod-2026-05

# Mail Configuration (use real provider in production)
MAIL_PROVIDER=mailrelay
MAILRELAY_API_KEY=your-mailrelay-api-key
MAILRELAY_API_URL=https://your-mailrelay-api-url
MAIL_WORKER_ENABLED=true
MAIL_SMOKE_TO=admin@example.com
MAIL_FROM_NOREPLY=noreply@projtrack.codes
MAIL_FROM_ADMIN=admin@projtrack.codes
MAIL_FROM_INVITE=invite@projtrack.codes
MAIL_FROM_NOTIFY=notify@projtrack.codes
MAIL_FROM_SUPPORT=support@projtrack.codes

# File Storage Configuration (use S3 in production)
OBJECT_STORAGE_MODE=s3
S3_BUCKET=your-s3-bucket-name
S3_REGION=your-s3-region
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
S3_SIGNED_URL_TTL_SECONDS=300
S3_BUCKET_PUBLIC=false
FILE_MALWARE_SCAN_MODE=fail-closed
FILE_MALWARE_SCANNER=clamav
CLAMAV_HOST=your-clamav-host
CLAMAV_PORT=3310

# Smoke Test Accounts (use test accounts for validation)
SMOKE_ADMIN_EMAIL=admin-test@projtrack.codes
SMOKE_ADMIN_PASSWORD=secure-test-password
SMOKE_TEACHER_EMAIL=teacher-test@projtrack.codes
SMOKE_TEACHER_PASSWORD=secure-test-password
SMOKE_STUDENT_EMAIL=student-test@projtrack.codes
SMOKE_STUDENT_PASSWORD=secure-test-password

# Other Configurations
NODE_ENV=production
APP_ENV=production
HTTP_RATE_LIMIT_STORE=redis
BACKUP_WORKER_ENABLED=true
BACKUP_SCHEDULE_ENABLED=true
BACKUP_WORKER_POLL_MS=3600000

# Frontend Configuration
VITE_USE_BACKEND=true
VITE_API_BASE_URL=https://api.projtrack.codes
VITE_PUBLIC_APP_URL=https://www.projtrack.codes
