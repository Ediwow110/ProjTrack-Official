# ProjTrack STAGING environment template.
# Same shape as production.env.example. APP_ENV=staging is accepted by
# runtime-safety.ts as a production-grade environment, so all hardening
# checks remain active.

# ----- Identity -----
NODE_ENV=production
APP_ENV=staging
APP_URL=https://staging.projtrack.codes
FRONTEND_URL=https://staging.projtrack.codes
BACKEND_URL=https://api-staging.projtrack.codes
CORS_ORIGINS=https://staging.projtrack.codes
COOKIE_DOMAIN=projtrack.codes
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
TRUST_PROXY=true
TRUST_PROXY_HOPS=1
PORT=3002

# ----- Database (DO Managed Postgres - staging cluster) -----
DATABASE_URL=postgresql://USER:PASS@STAGING_HOST:25060/projtrack_staging?sslmode=require

# ----- JWT (distinct from production) -----
JWT_ACCESS_SECRET=REPLACE_WITH_60_BYTE_BASE64_STAGING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_60_BYTE_BASE64_STAGING
JWT_ISSUER=projtrack-api
JWT_AUDIENCE=projtrack-web-staging
JWT_KEY_ID=staging-1

ACCOUNT_ACTION_TOKEN_ENC_KEY=REPLACE_WITH_32_BYTE_BASE64_STAGING

# ----- Mail (use a Mailrelay test list, NOT the prod list) -----
MAIL_PROVIDER=mailrelay
MAILRELAY_API_URL=https://projtrack.ipzmarketing.com/api/v1
MAILRELAY_API_KEY=REPLACE_WITH_STAGING_MAILRELAY_KEY
MAIL_FROM_NAME=ProjTrack Staging
MAIL_FROM_ADMIN=admin@projtrack.codes
MAIL_FROM_NOREPLY=support@projtrack.codes
MAIL_FROM_INVITE=support@projtrack.codes
MAIL_FROM_NOTIFY=notification@projtrack.codes
MAIL_FROM_SUPPORT=support@projtrack.codes
TESTMAIL_ENABLED=true

MAIL_WORKER_ENABLED=false
MAIL_WORKER_POLL_MS=5000

# ----- Object storage (separate staging bucket) -----
OBJECT_STORAGE_MODE=s3
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_REGION=sgp1
S3_BUCKET=projtrack-staging-uploads
S3_BUCKET_PUBLIC=false
S3_ACCESS_KEY_ID=REPLACE_WITH_STAGING_SPACES_KEY
S3_SECRET_ACCESS_KEY=REPLACE_WITH_STAGING_SPACES_SECRET
S3_SIGNED_URL_TTL_SECONDS=300

HTTP_RATE_LIMIT_STORE=database

FILE_MALWARE_SCAN_MODE=fail-closed
FILE_MALWARE_SCANNER=clamav
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

BACKUP_WORKER_ENABLED=false
BACKUP_SCHEDULE_ENABLED=false
BACKUP_WORKER_POLL_MS=3600000

ALLOW_DEMO_SEED=true
ALLOW_SEED_DATA_CLEANUP=true
ALLOW_PRODUCTION_ADMIN_TOOL_RUNS=false
