DATABASE_URL=postgresql://<db-user>:<db-password>@<db-host>:5432/<db-name>?schema=public
PORT=3001

# Environment
NODE_ENV=production
APP_ENV=production

APP_URL=https://www.projtrack.codes
CORS_ORIGINS=https://www.projtrack.codes,https://projtrack.codes

JWT_ACCESS_SECRET=<generate-a-long-random-access-secret>
JWT_REFRESH_SECRET=<generate-a-different-long-random-refresh-secret>

# Email provider
MAIL_PROVIDER=mailrelay
MAIL_FROM_NAME=ProjTrack
MAIL_FROM_ADMIN=admin@projtrack.codes
MAIL_FROM_NOREPLY=support@projtrack.codes
MAIL_FROM_INVITE=support@projtrack.codes
MAIL_FROM_NOTIFY=notification@projtrack.codes
MAIL_FROM_SUPPORT=support@projtrack.codes
MAIL_WORKER_ENABLED=false

# Sender.net backup provider
# Keep Sender.net disabled unless a future provider cutover is explicitly planned.
SENDER_API_KEY=<optional-backup-sender-api-key>
SENDER_API_URL=https://api.sender.net/v2/message/send
SENDER_MONTHLY_LIMIT=15000
SENDER_DAILY_SAFETY_LIMIT=1000

# Mailrelay active production provider
MAILRELAY_API_KEY=<mailrelay-api-key>
MAILRELAY_API_URL=https://projtrack.ipzmarketing.com/api/v1
MAILRELAY_MONTHLY_LIMIT=80000
MAILRELAY_DAILY_SAFETY_LIMIT=2000
MAILRELAY_BULK_PER_MIN=20
MAILRELAY_TX_PER_MIN=60

# testmail.app - development only. Leave unset in production.
TESTMAIL_ENABLED=false
# TESTMAIL_NAMESPACE=<development-only-namespace>
# TEST_EMAIL_ACTIVATION=<development-only-testmail-address>
# TEST_EMAIL_PASSWORD_RESET=<development-only-testmail-address>
# TEST_EMAIL_INVITE=<development-only-testmail-address>
# TEST_EMAIL_NOTIFICATION=<development-only-testmail-address>

# Admin-only student import limits. Prefer CSV for large imports.
STUDENT_IMPORT_MAX_FILE_MB=5
STUDENT_IMPORT_MAX_ROWS=1000
STUDENT_IMPORT_MAX_COLUMNS=32
STUDENT_IMPORT_MAX_SHEETS=1

OBJECT_STORAGE_MODE=s3
S3_BUCKET=<private-prod-bucket>
S3_REGION=<bucket-region>
S3_ENDPOINT=<https://your-s3-compatible-endpoint>
S3_ACCESS_KEY_ID=<s3-access-key-id>
S3_SECRET_ACCESS_KEY=<s3-secret-access-key>
S3_FORCE_PATH_STYLE=false

# Backup worker: set true only in one dedicated worker process.
BACKUP_WORKER_ENABLED=false
BACKUP_INTERVAL_HOURS=24
BACKUP_LOCAL_DIR=backend/data/system-tools/backups
# Future storage providers; do not commit credentials.
BACKUP_STORAGE=local
# GOOGLE_DRIVE_CLIENT_ID=<future-gdrive-client-id>
# GOOGLE_DRIVE_CLIENT_SECRET=<future-gdrive-client-secret>
# GOOGLE_DRIVE_FOLDER_ID=<future-gdrive-folder-id>

ALLOW_DEMO_SEED=false
ALLOW_SEED_DATA_CLEANUP=false
ALLOW_PRODUCTION_ADMIN_TOOL_RUNS=false
