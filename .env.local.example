# Example environment variables for local development

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/projtrack_dev

# Application URLs
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Authentication Secrets (use dummy values for local dev)
JWT_ACCESS_SECRET=local-access-secret-for-dev-only-not-production
JWT_REFRESH_SECRET=local-refresh-secret-for-dev-only-not-production
ACCOUNT_ACTION_TOKEN_ENC_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# Mail Configuration (use stub for local dev)
MAIL_PROVIDER=stub
MAIL_FROM=noreply@projtrack.local
MAIL_WORKER_ENABLED=false
MAIL_WORKER_POLL_MS=60000

# File Storage Configuration (use local for dev)
FILE_STORAGE_MODE=local
OBJECT_STORAGE_MODE=local

# Other Configurations
HTTP_RATE_LIMIT_STORE=memory
FILE_MALWARE_SCAN_MODE=disabled
BACKUP_WORKER_ENABLED=false
BACKUP_SCHEDULE_ENABLED=false
BACKUP_WORKER_POLL_MS=60000

# Frontend Configuration
VITE_USE_BACKEND=true
VITE_API_BASE_URL=http://localhost:3001
VITE_PUBLIC_APP_URL=http://localhost:5173
