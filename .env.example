# Frontend production build placeholders.
# For local development, scripts/start-local.ps1 injects localhost values automatically.
VITE_USE_BACKEND=true
VITE_API_BASE_URL=https://api.your-production-domain.example
VITE_PUBLIC_APP_URL=https://www.your-production-domain.example
VITE_ENABLE_CLIENT_ERROR_REPORTING=true
VITE_ENABLE_OFFLINE_BANNER=true
VITE_ENABLE_NETWORK_OVERLAY=true
VITE_ENABLE_REAL_ACCOUNT_SMOKE_DOCS=true
