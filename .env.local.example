# Example environment variables for local development

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/projtrack_dev

# Application URLs
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Authentication Secrets - dummy local placeholders only
JWT_ACCESS_SECRET=REPLACE_WITH_LOCAL_DEV_ACCESS_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_LOCAL_DEV_REFRESH_SECRET
ACCOUNT_ACTION_TOKEN_ENC_KEY=REPLACE_WITH_LOCAL_DEV_32_BYTE_BASE64_KEY

# Mail Configuration - local stub
MAIL_PROVIDER=stub
MAIL_FROM=noreply@projtrack.local
MAIL_WORKER_ENABLED=false
MAIL_WORKER_POLL_MS=60000

# File Storage Configuration - local only
FILE_STORAGE_MODE=local
OBJECT_STORAGE_MODE=local

# Other Configurations
HTTP_RATE_LIMIT_STORE=memory
FILE_MALWARE_SCAN_MODE=disabled
BACKUP_WORKER_ENABLED=false
BACKUP_SCHEDULE_ENABLED=false
BACKUP_WORKER_POLL_MS=60000