# Example environment variables for production environment.
#
# This file is a SUPERSET that documents every production variable across the
# API service, worker service, and frontend. Real values must be set in the
# hosting provider's secret manager — never committed.
#
# IMPORTANT: API service vs worker service flags differ. See the
# "Worker / scheduler flags" section below for the API↔worker matrix. The
# canonical per-service template is `backend/.env.production.example`.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=<production-postgres-url>

# ---------------------------------------------------------------------------
# Application URLs (must be https:// in production; never localhost)
# ---------------------------------------------------------------------------
APP_URL=https://www.projtrack.codes
FRONTEND_URL=https://www.projtrack.codes
BACKEND_URL=https://api.projtrack.codes
CORS_ORIGINS=https://www.projtrack.codes
TRUST_PROXY=true
TRUST_PROXY_HOPS=1

# ---------------------------------------------------------------------------
# Authentication secrets (generate strong unique values per environment)
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=<generate-strong-random-secret>
JWT_REFRESH_SECRET=<generate-different-strong-random-secret>
JWT_ISSUER=projtrack-api
JWT_AUDIENCE=projtrack-web
JWT_KEY_ID=prod-1
ACCOUNT_ACTION_TOKEN_ENC_KEY=<generate-strong-encryption-key>
AUTH_REFRESH_COOKIE_NAME=__Secure-projtrack_refresh
AUTH_REFRESH_COOKIE_SAME_SITE=lax
AUTH_REFRESH_COOKIE_SECURE=true

# ---------------------------------------------------------------------------
# Mail (Mailrelay is the active production provider; non-Mailrelay providers are rejected
# at startup by runtime-safety.ts when NODE_ENV=production).
# ---------------------------------------------------------------------------
MAIL_PROVIDER=mailrelay
MAILRELAY_API_KEY=<production-mailrelay-api-key>
MAILRELAY_API_URL=https://projtrack.ipzmarketing.com/api/v1
MAIL_FROM_NAME=ProjTrack
MAIL_FROM_ADMIN=admin@projtrack.codes
MAIL_FROM_NOREPLY=support@projtrack.codes
MAIL_FROM_INVITE=support@projtrack.codes
MAIL_FROM_NOTIFY=notification@projtrack.codes
MAIL_FROM_SUPPORT=support@projtrack.codes
OBJECT_STORAGE_MODE=s3
S3_ACCESS_KEY_ID=<production-s3-access-key-id>
S3_SECRET_ACCESS_KEY=<production-s3-secret-access-key>
S3_BUCKET=<production-upload-bucket>
S3_BACKUP_BUCKET=<production-backup-bucket>
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_REGION=sgp1
S3_SIGNED_URL_TTL_SECONDS=300
S3_BUCKET_PUBLIC=false

# ---------------------------------------------------------------------------
# Malware scanning (must be fail-closed in production)
# ---------------------------------------------------------------------------
FILE_MALWARE_SCAN_MODE=fail-closed
FILE_MALWARE_SCANNER=clamav
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
NODE_ENV=production
APP_ENV=production
HTTP_RATE_LIMIT_STORE=database

# ---------------------------------------------------------------------------
# Worker / scheduler flags
#
# API service (the public NestJS process behind https://api.projtrack.codes):
#   MAIL_WORKER_ENABLED=false
#   BACKUP_WORKER_ENABLED=false
#   BACKUP_SCHEDULE_ENABLED=false
#
# Worker service (single dedicated process — never run more than one):
#   MAIL_WORKER_ENABLED=true
#   BACKUP_WORKER_ENABLED=true
#   BACKUP_SCHEDULE_ENABLED=true
#
# The values below are the WORKER values. On the API service, override all
# three to `false` so the public API never owns mail delivery or backups.
# ---------------------------------------------------------------------------
MAIL_WORKER_ENABLED=true
MAIL_WORKER_POLL_MS=15000
BACKUP_WORKER_ENABLED=true
BACKUP_SCHEDULE_ENABLED=true
BACKUP_STORAGE_PROVIDER=s3
BACKUP_STORAGE=s3
BACKUP_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Hardened admin tools (must stay false in production)
# ---------------------------------------------------------------------------
ALLOW_DEMO_SEED=false
ALLOW_SEED_DATA_CLEANUP=false
ALLOW_PRODUCTION_ADMIN_TOOL_RUNS=false

# ---------------------------------------------------------------------------
# Frontend (set in Vercel/static-host env, never on the backend)
# ---------------------------------------------------------------------------
VITE_USE_BACKEND=true
VITE_API_BASE_URL=https://api.projtrack.codes
VITE_PUBLIC_APP_URL=https://www.projtrack.codes
