# ProjTrack production environment template.
# Copy to /opt/projtrack/backend.env.production on the Droplet and fill in.
# Every value below is REQUIRED unless explicitly marked optional.
# runtime-safety.ts will refuse to boot if any required value is missing or
# does not look production-grade.

# ----- Identity -----
NODE_ENV=production
APP_ENV=production
APP_URL=https://projtrack.codes
FRONTEND_URL=https://projtrack.codes
BACKEND_URL=https://api.projtrack.codes
CORS_ORIGINS=https://projtrack.codes,https://www.projtrack.codes
COOKIE_DOMAIN=projtrack.codes
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
TRUST_PROXY=true
TRUST_PROXY_HOPS=1
PORT=3001

# ----- Database (DO Managed Postgres) -----
# Use the connection-pool URL with sslmode=require.
DATABASE_URL=postgresql://USER:PASS@HOST:25060/projtrack?sslmode=require

# ----- JWT (must each be >= 48 chars and DIFFERENT) -----
# Generate with: openssl rand -base64 60
JWT_ACCESS_SECRET=REPLACE_WITH_60_BYTE_BASE64
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_60_BYTE_BASE64
JWT_ISSUER=projtrack-api
JWT_AUDIENCE=projtrack-web
JWT_KEY_ID=prod-1

# ----- Account action token encryption (32-byte key, base64) -----
# Generate with: openssl rand -base64 32
ACCOUNT_ACTION_TOKEN_ENC_KEY=REPLACE_WITH_32_BYTE_BASE64

# ----- Mail (Mailrelay; stub is rejected in production) -----
MAIL_PROVIDER=mailrelay
MAILRELAY_API_URL=https://projtrack.ipzmarketing.com/api/v1
MAILRELAY_API_KEY=REPLACE_WITH_MAILRELAY_KEY
MAIL_FROM_NAME=ProjTrack
MAIL_FROM_ADMIN=admin@projtrack.codes
MAIL_FROM_NOREPLY=support@projtrack.codes
MAIL_FROM_INVITE=support@projtrack.codes
MAIL_FROM_NOTIFY=notification@projtrack.codes
MAIL_FROM_SUPPORT=support@projtrack.codes
TESTMAIL_ENABLED=false

# Mail worker (only the dedicated mail-worker container sets these to true)
MAIL_WORKER_ENABLED=false
MAIL_WORKER_POLL_MS=5000
MAIL_QUEUE_WARNING_MS=300000
MAIL_PROCESSING_WARNING_MS=300000
MAIL_PROCESSING_STALE_MS=600000

# ----- Object storage (DO Spaces; bucket MUST NOT be public) -----
OBJECT_STORAGE_MODE=s3
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_REGION=sgp1
S3_BUCKET=projtrack-prod-uploads
S3_BUCKET_PUBLIC=false
S3_ACCESS_KEY_ID=REPLACE_WITH_SPACES_KEY
S3_SECRET_ACCESS_KEY=REPLACE_WITH_SPACES_SECRET
S3_SIGNED_URL_TTL_SECONDS=300

# ----- Rate limit (database-backed; in-memory rejected in production) -----
HTTP_RATE_LIMIT_STORE=database

# ----- Malware scanning (fail-closed required; clamav reachable on the compose network) -----
FILE_MALWARE_SCAN_MODE=fail-closed
FILE_MALWARE_SCANNER=clamav
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ----- Backup worker (only the dedicated backup-worker container sets these to true) -----
BACKUP_WORKER_ENABLED=false
BACKUP_SCHEDULE_ENABLED=false
BACKUP_WORKER_POLL_MS=3600000
BACKUP_TARGET=spaces
BACKUP_S3_BUCKET=projtrack-prod-backups
BACKUP_RETENTION_DAYS=30

# ----- Hardening flags -----
ALLOW_DEMO_SEED=false
ALLOW_SEED_DATA_CLEANUP=false
ALLOW_PRODUCTION_ADMIN_TOOL_RUNS=false
