# Production environment for the DEDICATED WORKER process.
# Deploy this as a separate service from the API process.
# The worker shares the same DATABASE_URL as the API — they both read the same email job queue.

DATABASE_URL=postgresql://<db-user>:<db-password>@<db-host>:5432/<db-name>?schema=public
PORT=3002

# Environment — must match the API process
NODE_ENV=production
APP_ENV=production

APP_URL=https://www.projtrack.codes
FRONTEND_URL=https://www.projtrack.codes
BACKEND_URL=https://api.projtrack.codes
CORS_ORIGINS=https://www.projtrack.codes,https://projtrack.codes
TRUST_PROXY=true
TRUST_PROXY_HOPS=1

JWT_ACCESS_SECRET=<same-value-as-api-process>
JWT_REFRESH_SECRET=<same-value-as-api-process>
JWT_ISSUER=projtrack-api
JWT_AUDIENCE=projtrack-web
JWT_KEY_ID=prod-2026-01
ACCOUNT_ACTION_TOKEN_ENC_KEY=<same-value-as-api-process>

# Email provider — WORKER has MAIL_WORKER_ENABLED=true
MAIL_PROVIDER=mailrelay
MAIL_FROM_NAME=ProjTrack
MAIL_FROM_ADMIN=admin@projtrack.codes
MAIL_FROM_NOREPLY=support@projtrack.codes
MAIL_FROM_INVITE=support@projtrack.codes
MAIL_FROM_NOTIFY=notification@projtrack.codes
MAIL_FROM_SUPPORT=support@projtrack.codes
MAIL_WORKER_ENABLED=true
MAIL_WORKER_POLL_MS=60000

MAILRELAY_API_KEY=<mailrelay-api-key>
MAILRELAY_API_URL=https://projtrack.ipzmarketing.com/api/v1
MAILRELAY_MONTHLY_LIMIT=80000
MAILRELAY_DAILY_SAFETY_LIMIT=2000
MAILRELAY_BULK_PER_MIN=20
MAILRELAY_TX_PER_MIN=60

TESTMAIL_ENABLED=false

# Object storage — same as API process
OBJECT_STORAGE_MODE=s3
S3_BUCKET=<private-prod-bucket>
S3_REGION=<bucket-region>
S3_ENDPOINT=<https://your-s3-compatible-endpoint>
S3_ACCESS_KEY_ID=<s3-access-key-id>
S3_SECRET_ACCESS_KEY=<s3-secret-access-key>
S3_FORCE_PATH_STYLE=false
S3_SIGNED_URL_TTL_SECONDS=300
S3_BUCKET_PUBLIC=false

# File security — same as API
FILE_MALWARE_SCAN_MODE=fail-closed
FILE_MALWARE_SCANNER=clamav
CLAMAV_HOST=<clamav-host>
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000

HTTP_RATE_LIMIT_STORE=database

# WORKER has BACKUP_WORKER_ENABLED=true
BACKUP_LOCAL_DIR=data/system-tools/backups
BACKUP_WORKER_ENABLED=true
BACKUP_SCHEDULE_ENABLED=true
BACKUP_DEFAULT_FREQUENCY=daily
BACKUP_DEFAULT_TIME=02:00
BACKUP_TIMEZONE=Asia/Manila
BACKUP_RETENTION_DAYS=30
BACKUP_RETENTION_COUNT=10
BACKUP_WORKER_POLL_MS=60000
BACKUP_STORAGE_PROVIDER=local
BACKUP_STORAGE=local

ALLOW_DEMO_SEED=false
ALLOW_SEED_DATA_CLEANUP=false
ALLOW_PRODUCTION_ADMIN_TOOL_RUNS=false
